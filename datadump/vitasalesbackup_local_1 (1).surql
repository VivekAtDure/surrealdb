attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "If you throw in free installation, I'll sign right now.", conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:06.628916200Z', id: message:urym7fsognvz5ivr63xi, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Can we lock this price in for 24 months?', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:54.990342500Z', id: message:wa4jarq9nuc7bop3cut1, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'karan.b@bose.in, 3344556677', conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:36.062732400Z', id: message:wdudiv2uwtslsji0puwr, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'suresh@menon.co.in, 2233445566', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:51.146563400Z', id: message:xgm4eq8vv9maejb5n1gq, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'This is quite high. Can you give me a 10% discount?', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:49.928493300Z', id: message:y0yfrtt2q1l6h0kibbfb, message_type: 'TEXT', sender: 'CUSTOMER' } ];

