-- ------------------------------
-- TABLE: rolewise_component
-- ------------------------------

DEFINE TABLE rolewise_component TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD can_create ON rolewise_component TYPE bool DEFAULT false PERMISSIONS FULL;
DEFINE FIELD can_delete ON rolewise_component TYPE bool DEFAULT false PERMISSIONS FULL;
DEFINE FIELD can_edit ON rolewise_component TYPE bool DEFAULT false PERMISSIONS FULL;
DEFINE FIELD can_view ON rolewise_component TYPE bool DEFAULT true PERMISSIONS FULL;
DEFINE FIELD component_id ON rolewise_component TYPE record<master_component> ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD created_at ON rolewise_component TYPE datetime DEFAULT time::now() PERMISSIONS FULL;
DEFINE FIELD is_active ON rolewise_component TYPE bool DEFAULT true PERMISSIONS FULL;
DEFINE FIELD organisation_id ON rolewise_component TYPE record<organisation> ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD role_name ON rolewise_component TYPE string ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD updated_at ON rolewise_component TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX idx_role_component ON rolewise_component FIELDS role_name, component_id, organisation_id UNIQUE;
DEFINE INDEX idx_rolewise_role ON rolewise_component FIELDS role_name;


