-- ------------------------------
-- TABLE: organisation
-- ------------------------------

DEFINE TABLE organisation TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD accent_color ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD address ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD city ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD company_letterhead_pdf ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD country ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD created_at ON organisation TYPE datetime DEFAULT time::now() PERMISSIONS FULL;
DEFINE FIELD default_currency ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD email ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD esignature_upload_url ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD gst_number ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD industry ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD industry_type ON organisation TYPE string ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD name ON organisation TYPE string ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD pan_number ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD phone ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD pincode ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD primary_brand_color ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD realm ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD state ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD tax_regime ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD updated_at ON organisation TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD vat_number ON organisation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD website ON organisation TYPE none | string PERMISSIONS FULL;

DEFINE INDEX idx_org_name ON organisation FIELDS name;


