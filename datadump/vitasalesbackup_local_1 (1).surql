-- ------------------------------
-- TABLE: message
-- ------------------------------

DEFINE TABLE message TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD attachment_url ON message TYPE none | string PERMISSIONS FULL;
DEFINE FIELD attachments ON message TYPE none | array<string> PERMISSIONS FULL;
DEFINE FIELD attachments.* ON message TYPE string PERMISSIONS FULL;
DEFINE FIELD content ON message TYPE string PERMISSIONS FULL;
DEFINE FIELD conversation ON message TYPE record<conversation> PERMISSIONS FULL;
DEFINE FIELD created_at ON message TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD embedding ON message TYPE none | array PERMISSIONS FULL;
DEFINE FIELD embedding.* ON message TYPE any PERMISSIONS FULL;
DEFINE FIELD message_type ON message TYPE string DEFAULT 'TEXT' ASSERT $value INSIDE ['TEXT', 'IMAGE', 'AUDIO', 'VIDEO', 'DOCUMENT', 'LOCATION'] PERMISSIONS FULL;
DEFINE FIELD sender ON message TYPE string ASSERT $value INSIDE ['CUSTOMER', 'AGENT', 'BOT'] PERMISSIONS FULL;

DEFINE INDEX msg_conv_idx ON message FIELDS conversation;


-- ------------------------------
-- TABLE DATA: message
-- ------------------------------

INSERT [ { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'ali@qureshi.net, phone is 8877887788', conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:11.651107900Z', id: message:04tq8h632cl39zvj6skj, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'URGENT: I need a chiller delivered by tomorrow.', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:53.096804900Z', id: message:0a5f11wmt2oaah8rf150, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Yes, 1 unit.', conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:13.845328200Z', id: message:0l50qezk6s921a77mmr3, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Here is the quotation for 2 units.', conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:24.284331800Z', id: message:0pxb0jagc8vzif2l0suz, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Approved. Dispatch it immediately.', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:59.147479500Z', id: message:0sc7wjtp77f4exsg6t7b, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Management approved. Free installation included.', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:07.536384700Z', id: message:0tjdrvbmqlryw3zhsa6a, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi Fatima! Can I get your email and phone so I can send the evaporative cooler pricing guide?', conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:42.112449600Z', id: message:0yolc1j3cgf1la2f1a0f, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Looks great. Please proceed with the order.', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:41.451911100Z', id: message:16rb8kvsyp6826z45mk6, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'rahul@kapoor.inc and 5544332211', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:45.728115600Z', id: message:19ejqih5yqmpm2jwzlg9, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'I need to repeat my order from last year.', conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:34.246901Z', id: message:1g26pkxevrebtul3oz8r, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'I need 6 coolers of 125 gallons.', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:39.381185700Z', id: message:3me6nt63u4f72wp8jlf1, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Attached is the annual contract quote for 5 units/month.', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:53.950475100Z', id: message:3tn0f42398ednjb35aok, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'fatima@alrashid.com, 6655443322', conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:43.161511Z', id: message:44u4bec3ebdp4b877lxw, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Perfect. Please check the attached quotation.', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:40.276209900Z', id: message:4izrv5eqmnad7tgjao8q, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi Suresh! We love annual contracts. Please share your email and phone so I can set up a vendor profile.', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:50.069603200Z', id: message:4k2sarwytogrw6c2a98r, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'We have it in stock. Attached is the quote with the express delivery surcharge.', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:58.035587900Z', id: message:4whbv9pkgu799myaygvv, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi, I need a cooler for my office.', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:34.951241800Z', id: message:4z8py0hkgpieckjwljcq, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Sure, email is aisha@verma.com and phone is 1231231234', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:37.440456700Z', id: message:5ds4n9vi6s1n6un46g8n, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: '5 units a month.', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:53.035357800Z', id: message:5eur8xghev6v6m6uiv3a, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Nobody replied to my email! I need 3 chillers now.', conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42:26.667504100Z', id: message:5mxywe1jos5qq7m6p40w, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Thank you. Just 1 unit of the DC45000?', conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:12.611579300Z', id: message:6eobgwxis4hpgelxvlu6, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "Can you match a competitor's price on the 45 Ton chiller?", conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:09.709117400Z', id: message:8poihvxgputhfs29fy8p, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: '1 unit of DC5000.', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:57.191009600Z', id: message:9sdfphe4kq21ac7bgfps, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "Fine, let's do it.", conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:51.751748700Z', id: message:9tw022ihush8n39orriz, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Great, issuing PO.', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:08.498797800Z', id: message:abvk63gzkejeyfun9yye, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Got it. What capacity chiller do you require?', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:46.697629700Z', id: message:aictpys0a1ri8r5okua9, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Noted. Which model do you need rushed?', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:56.027260900Z', id: message:am31zv28t6wwo2z3hkir, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Confirmed.', conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:39.980838700Z', id: message:bfg7uw4j039tk2e2fwpt, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Absolutely. I can email the datasheet. What is your email and phone?', conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:20.072632Z', id: message:bh1j257qsv7usj5istwh, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Thank you! How many DEC24000 units do you need?', conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:44.062534400Z', id: message:bl83r7vz8i6f6abadk6k, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Just 2 units.', conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:23.513212400Z', id: message:bnu9xdusc3yi06dy08zy, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Understood. The quote is valid for 30 days if you change your mind.', conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:48.189768500Z', id: message:bu048rq4ai61bhfinvwx, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hello Vikram, bulk pricing is available. Please share your email and phone so I can send the project catalog.', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:01.092060200Z', id: message:c5x9rztsanbjlqcf8n23, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'email is vikram.j@build.com, phone is 1122112211', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:02.056979400Z', id: message:cc9eekevq6q0vyqe3f7w, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Here is the quotation.', conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:46.135077800Z', id: message:chrlcnnqye88j684d8lt, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi Sara, we can expedite! Please provide your email and phone immediately so I can check stock.', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:53.977164600Z', id: message:cnl4k3sklswle5hph3j6, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Found it. You wanted the 7.5 Ton chillers. Generating priority quote.', conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42:29.638409600Z', id: message:cos4n2emxy5io8z5pv4o, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "Specs look good. Let's proceed.", conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:25.378342Z', id: message:czvl2pb15q6key926as7, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Looking to set up an annual supply of chillers.', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:49.262341800Z', id: message:dl4q3wb1x216ty05o08g, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "Excellent, let's sign the contract.", conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:56.861388700Z', id: message:f3nci6ud673e2imnswq9, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Here is the quotation for 2 units.', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:48.736448Z', id: message:gf9qe4cv6n2pdg28yhc3, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Here is our competitive quotation.', conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:14.748362600Z', id: message:gfq0rgbf8n8hrn9ehaa3, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi Ali, we usually can! Please provide your email and phone so I can look up our best rate.', conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:10.609351100Z', id: message:gpx3f1g2o2a7kpilz262, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Yes, exact same.', conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:37.988078800Z', id: message:gqoidnd7b3hswqxj6szy, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi Aisha, to proceed with the inquiry, please share your email id and phone number.', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:36.136447500Z', id: message:h13s4h2k8656g2x30x93, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: '2 units of the 10 Ton DC10000.', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:47.843206600Z', id: message:hzk5vac2xntqnt8fgvko, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Order confirmed! Thank you.', conversation: conversation:ao5vjvuy9lwricmzy3qo, created_at: d'2026-04-21T05:41:42.437166400Z', id: message:itwhbmufun6oz5qi8p1v, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Looking for chiller prices.', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:43.584490400Z', id: message:j44dmu3jbyf1uj2xhwg5, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Reorder quote attached.', conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:38.811098700Z', id: message:jf637phdh8pbbzjuhtj2, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Datasheet sent. How many DWC150-5 units do you need quoted?', conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:22.336998200Z', id: message:jrfkwgxwr8zpcjp1u2bz, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hello Rahul, happy to help. Can I get your email and phone number to create a file?', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:44.540126800Z', id: message:k8nht49s5qnsrk2cqyzw, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "Welcome back Karan! Please confirm your email and phone so I can pull up last year's order.", conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:35.112072500Z', id: message:kax8dvj7mv5k45vnfynl, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'pooja.i@mail.com, 4433221100', conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:21.273779200Z', id: message:lfbby1ddmt5856lf0zpf, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Got it. You bought 4 DWC65-3 coolers. Want the exact same?', conversation: conversation:acezatuto3bq34yu5usx, created_at: d'2026-04-21T05:42:36.879410300Z', id: message:llttknuufboqscbtzrg9, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Hi, I need technical specs for the 150 Gallon cooler before I order.', conversation: conversation:c4wnstf7m7cf86m37025, created_at: d'2026-04-21T05:42:19.187887800Z', id: message:lmgvkju7duo714d64k3g, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'DWC25-2.', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:04.135526Z', id: message:m402zjpzvg6gjj4perdm, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Thank you. Which specific cooler model do you need 20 units of?', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:02.924220400Z', id: message:n4852dk2uk67qo7u7jq0, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'sara.n@fastmail.com, phone 9988776655', conversation: conversation:1ipw3ylhqnxmzlx9ir1y, created_at: d'2026-04-21T05:41:55.057949200Z', id: message:nrn8kxh5muqdsqamdpn7, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "I'm looking at other options, your price is too high.", conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:47.346673400Z', id: message:ojac4brv9nffljwsitqv, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'I sincerely apologize! Let me personally handle this. Can you confirm your email and phone so I can locate the lost thread?', conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42:27.550172100Z', id: message:ojrviq126s9efxxel53w, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'I can offer a 5% discount to close this today. Revised quote sent.', conversation: conversation:l6zmdf6xemckpvb89t8v, created_at: d'2026-04-21T05:41:50.798763600Z', id: message:pcxjrtzn55rcmerqxbdj, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Fair enough. Confirmed.', conversation: conversation:m8tl93jb6lt4d341fe8a, created_at: d'2026-04-21T05:42:17.943975300Z', id: message:pozmuoyd2y88f69pj33j, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Priority quote attached with an apology discount.', conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42:31.756290900Z', id: message:q5eofsqi63cvlyjimmlh, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Yes, 24-month price lock is approved.', conversation: conversation:vsofuskehgph8g9iexw3, created_at: d'2026-04-21T05:42:55.910416100Z', id: message:qd7om9lkcw14w4azz16f, message_type: 'TEXT', sender: 'AGENT' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'omar.s@domain.com, 7766554433.', conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42:28.702922800Z', id: message:qo1ng8yvbvbm10601hlp, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Need quotes for 20 coolers for a new project.', conversation: conversation:ofsie655hrfbeg6kmcra, created_at: d'2026-04-21T05:42:00.284770500Z', id: message:qva69wn0z67h0lddnahc, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: '10 units.', conversation: conversation:sfskxwzns24awx2p8j1w, created_at: d'2026-04-21T05:42:45.089774Z', id: message:r0ups1k4kufma822kt94, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: "Okay, that's better. Order it.", conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42:32.920038800Z', id: message:rc68ys73lxo1j8buu4kh, message_type: 'TEXT', sender: 'CUSTOMER' }, { attachments: ['https://cmsvital.imonitorplus.com/uploads/segment_0_2_dee54fa264.png'], content: 'Yes, 3 of the DC7500.', conversation: conversation:2o1nymunh83j5ubumtly, created_at: d'2026-04-21T05:42: