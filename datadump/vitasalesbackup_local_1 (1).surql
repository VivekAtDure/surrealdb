-- ------------------------------
-- TABLE: contact
-- ------------------------------

DEFINE TABLE contact TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD created_at ON contact TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD email ON contact TYPE none | string PERMISSIONS FULL;
DEFINE FIELD name ON contact TYPE none | string PERMISSIONS FULL;
DEFINE FIELD phone ON contact TYPE none | string PERMISSIONS FULL;
