DEFINE TABLE lead_identity TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD identity_type ON lead_identity TYPE string PERMISSIONS FULL;
DEFINE FIELD identity_value ON lead_identity TYPE string PERMISSIONS FULL;
DEFINE FIELD master_id ON lead_identity TYPE string PERMISSIONS FULL;

DEFINE INDEX unique_identity ON lead_identity FIELDS identity_value, identity_type UNIQUE;


