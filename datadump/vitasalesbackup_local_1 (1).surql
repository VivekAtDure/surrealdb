-- ------------------------------

DEFINE TABLE lead_identity_map TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD created_at ON lead_identity_map TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD identity_type ON lead_identity_map TYPE string ASSERT $value INSIDE ['voice', 'email', 'whatsapp'] PERMISSIONS FULL;
DEFINE FIELD identity_value ON lead_identity_map TYPE string PERMISSIONS FULL;
DEFINE FIELD lead ON lead_identity_map TYPE record<lead> PERMISSIONS FULL;



