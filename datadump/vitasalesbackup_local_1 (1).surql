-- ------------------------------
-- TABLE: event_log
-- ------------------------------

DEFINE TABLE event_log TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD channel ON event_log TYPE none | record<channel> PERMISSIONS FULL;
DEFINE FIELD created_at ON event_log TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD event_type ON event_log TYPE string PERMISSIONS FULL;
DEFINE FIELD lead_id ON event_log TYPE string PERMISSIONS FULL;
DEFINE FIELD lead_state ON event_log TYPE none | string PERMISSIONS FULL;
DEFINE FIELD payload ON event_log TYPE none | object FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD triggered_by ON event_log TYPE string DEFAULT 'system' PERMISSIONS FULL;

DEFINE INDEX evtlog_lead_idx ON event_log FIELDS lead_id;
DEFINE INDEX evtlog_type_idx ON event_log FIELDS event_type;

DEFINE EVENT event_log_graph_edge ON event_log WHEN $event = 'CREATE' THEN { LET $l = type::record($after.lead_id); (RELATE $l -> generated_event -> $after).id; };

-- ------------------------------
-- TABLE DATA: event_log
-- ------------------------------

