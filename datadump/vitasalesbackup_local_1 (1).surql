-- ------------------------------
-- TABLE: master_product_price_list
-- ------------------------------

DEFINE TABLE master_product_price_list TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD category ON master_product_price_list TYPE string PERMISSIONS FULL;
DEFINE FIELD created_at ON master_product_price_list TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD description ON master_product_price_list TYPE string PERMISSIONS FULL;
DEFINE FIELD exworks_price_aed ON master_product_price_list TYPE number PERMISSIONS FULL;
DEFINE FIELD installation_charge ON master_product_price_list TYPE number PERMISSIONS FULL;
DEFINE FIELD model ON master_product_price_list TYPE string PERMISSIONS FULL;
DEFINE FIELD organisation ON master_product_price_list TYPE none | record<organisation> PERMISSIONS FULL;
DEFINE FIELD purchase_price ON master_product_price_list TYPE none | number PERMISSIONS FULL;
DEFINE FIELD sku ON master_product_price_list TYPE string PERMISSIONS FULL;
DEFINE FIELD vat_percent ON master_product_price_list TYPE number PERMISSIONS FULL;



