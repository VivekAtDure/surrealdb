 followup_period: 'ONCE', id: lead_stage:vz1y2mr4myacyxzzpcr5, is_quotation: false, is_terminal: false, organisation: organisation:1, stage_key: 'NEW_LEAD', stage_name: 'New Lead', stage_order: 1, updated_at: d'2026-04-06T19:54:47.107708500Z' } ];

-- ------------------------------
-- TABLE: lead_state_history
-- ------------------------------

DEFINE TABLE lead_state_history TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD channel ON lead_state_history TYPE none | record<channel> PERMISSIONS FULL;
DEFINE FIELD created_at ON lead_state_history TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD from_state ON lead_state_history TYPE none | string PERMISSIONS FULL;
DEFINE FIELD lead_id ON lead_state_history TYPE string PERMISSIONS FULL;
DEFINE FIELD to_state ON lead_state_history TYPE string PERMISSIONS FULL;
DEFINE FIELD triggered_by ON lead_state_history TYPE string DEFAULT 'system' PERMISSIONS FULL;

DEFINE INDEX lsh_lead_idx ON lead_state_history FIELDS lead_id;

DEFINE EVENT state_graph_edge ON lead_state_history WHEN $event = 'CREATE' THEN { LET $l = type::record($after.lead_id); (RELATE $l -> had_state -> $after).id; };

-- ------------------------------
-- TABLE DATA: lead_state_history
-- ------------------------------

