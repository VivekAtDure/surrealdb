-- ------------------------------
-- TABLE: sales_event
-- ------------------------------

DEFINE TABLE sales_event TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD created_at ON sales_event TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD entity ON sales_event TYPE string PERMISSIONS FULL;
DEFINE FIELD entity_id ON sales_event TYPE string PERMISSIONS FULL;
DEFINE FIELD payload ON sales_event TYPE none | object FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD processed_at ON sales_event TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD state ON sales_event TYPE string DEFAULT 'CREATED' ASSERT $value INSIDE ['CREATED', 'PROCESSING', 'COMPLETED', 'RETRYING', 'FAILED'] PERMISSIONS FULL;
DEFINE FIELD type ON sales_event TYPE string PERMISSIONS FULL;
DEFINE FIELD updated_at ON sales_event TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX se_state_idx ON sales_event FIELDS state;


-- ------------------------------
-- TABLE DATA: sales_event
-- ------------------------------


-- ------------------------------
-- TABLE: same_identity
-- ------------------------------

DEFINE TABLE same_identity TYPE RELATION IN lead OUT lead SCHEMALESS PERMISSIONS NONE;

DEFINE FIELD in ON same_identity TYPE record<lead> PERMISSIONS FULL;
DEFINE FIELD out ON same_identity TYPE record<lead> PERMISSIONS FULL;



-- ------------------------------
-- TABLE DATA: same_identity
-- ------------------------------


-- ------------------------------
-- TABLE: same_person
-- ------------------------------

DEFINE TABLE same_person TYPE ANY SCHEMALESS PERMISSIONS NONE;




-- ------------------------------
-- TABLE DATA: same_person
-- ------------------------------


-- ------------------------------
-- TABLE: scheduled_event
-- ------------------------------

DEFINE TABLE scheduled_event TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD assigned_agent ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD channel ON scheduled_event TYPE none | record<channel> PERMISSIONS FULL;
DEFINE FIELD created_at ON scheduled_event TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD created_by ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD cron_expression ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD error_message ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD event_name ON scheduled_event TYPE string PERMISSIONS FULL;
DEFINE FIELD event_type ON scheduled_event TYPE string ASSERT $value INSIDE ['FOLLOWUP', 'REMINDER', 'RETRY', 'ESCALATION', 'CUSTOM'] PERMISSIONS FULL;
DEFINE FIELD fired_count ON scheduled_event TYPE int DEFAULT 0 PERMISSIONS FULL;
DEFINE FIELD job_key ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD last_fired_at ON scheduled_event TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD lead_id ON scheduled_event TYPE string PERMISSIONS FULL;
DEFINE FIELD locked_at ON scheduled_event TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD locked_by ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD max_repeats ON scheduled_event TYPE int DEFAULT 1 PERMISSIONS FULL;
DEFINE FIELD misfire_policy ON scheduled_event TYPE string DEFAULT 'FIRE_ONCE' ASSERT $value INSIDE ['FIRE_ONCE', 'IGNORE', 'SMART'] PERMISSIONS FULL;
DEFINE FIELD next_fire_at ON scheduled_event TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD payload ON scheduled_event TYPE none | object FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD period ON scheduled_event TYPE string DEFAULT 'ONCE' ASSERT $value INSIDE ['ONCE', 'MINUTES', 'HOURLY', 'DAILY', 'WEEKLY', 'MONTHLY'] PERMISSIONS FULL;
DEFINE FIELD period_value ON scheduled_event TYPE none | int PERMISSIONS FULL;
DEFINE FIELD repeat_count ON scheduled_event TYPE int DEFAULT 0 PERMISSIONS FULL;
DEFINE FIELD scheduled_at ON scheduled_event TYPE datetime PERMISSIONS FULL;
DEFINE FIELD status ON scheduled_event TYPE string DEFAULT 'PENDING' ASSERT $value INSIDE ['PENDING', 'PROCESSING', 'COMPLETED', 'FAILED', 'CANCELLED'] PERMISSIONS FULL;
DEFINE FIELD trigger_key ON scheduled_event TYPE none | string PERMISSIONS FULL;
DEFINE FIELD updated_at ON scheduled_event TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX se_lead_idx ON scheduled_event FIELDS lead_id;
DEFINE INDEX se_pending_due ON scheduled_event FIELDS status, scheduled_at;
DEFINE INDEX se_period_idx ON scheduled_event FIELDS period;
DEFINE INDEX se_status_idx ON scheduled_event FIELDS status;


-- ------------------------------
-- TABLE DATA: scheduled_event
-- ------------------------------


