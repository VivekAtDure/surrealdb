-- ------------------------------
-- TABLE: master_component
-- ------------------------------

DEFINE TABLE master_component TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD component_key ON master_component TYPE string ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD component_name ON master_component TYPE string ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD created_at ON master_component TYPE datetime DEFAULT time::now() PERMISSIONS FULL;
DEFINE FIELD description ON master_component TYPE none | string PERMISSIONS FULL;
DEFINE FIELD is_active ON master_component TYPE bool DEFAULT true PERMISSIONS FULL;
DEFINE FIELD sort_order ON master_component TYPE int DEFAULT 0 PERMISSIONS FULL;
DEFINE FIELD updated_at ON master_component TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX idx_component_key ON master_component FIELDS component_key UNIQUE;


-- ------------------------------
-- TABLE DATA: master_component
-- ------------------------------

