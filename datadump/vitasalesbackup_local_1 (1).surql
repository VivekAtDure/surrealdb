-- ------------------------------
-- TABLE: lead_status
-- ------------------------------

DEFINE TABLE lead_status TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD created_at ON lead_status TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD external_source_leadid ON lead_status TYPE none | string PERMISSIONS FULL;
DEFINE FIELD lead_status ON lead_status TYPE string PERMISSIONS FULL;
DEFINE FIELD leadid ON lead_status TYPE string PERMISSIONS FULL;
DEFINE FIELD organisation ON lead_status TYPE none | record<organisation> PERMISSIONS FULL;
DEFINE FIELD previous_status ON lead_status TYPE none | string PERMISSIONS FULL;
DEFINE FIELD source_channel ON lead_status TYPE none | record<channel> PERMISSIONS FULL;
DEFINE FIELD triggered_by ON lead_status TYPE string DEFAULT 'system' PERMISSIONS FULL;
DEFINE FIELD updated_at ON lead_status TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX ls_lead_idx ON lead_status FIELDS leadid;


-- ------------------------------
-- TABLE DATA: lead_status
