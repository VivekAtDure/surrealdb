DEFINE TABLE contact_identity_map TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD contact ON contact_identity_map TYPE record<contact> PERMISSIONS FULL;
DEFINE FIELD created_at ON contact_identity_map TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD identity_type ON contact_identity_map TYPE string ASSERT $value INSIDE ['PHONE', 'EMAIL', 'WHATSAPP'] PERMISSIONS FULL;
DEFINE FIELD identity_value ON contact_identity_map TYPE string PERMISSIONS FULL;

DEFINE INDEX unique_identity ON contact_identity_map FIELDS identity_value, identity_type UNIQUE;


