-- ------------------------------
-- TABLE: contact_master_map
-- ------------------------------

DEFINE TABLE contact_master_map TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD created_at ON contact_master_map TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD known_emails ON contact_master_map TYPE array PERMISSIONS FULL;
DEFINE FIELD known_phones ON contact_master_map TYPE array PERMISSIONS FULL;
DEFINE FIELD known_whatsapps ON contact_master_map TYPE array PERMISSIONS FULL;
DEFINE FIELD leads ON contact_master_map TYPE array PERMISSIONS FULL;
DEFINE FIELD linkage_id ON contact_master_map TYPE string PERMISSIONS FULL;
DEFINE FIELD organisation ON contact_master_map TYPE none | record<organisation> PERMISSIONS FULL;
DEFINE FIELD primary_lead ON contact_master_map TYPE none | record<lead> PERMISSIONS FULL;
DEFINE FIELD status ON contact_master_map TYPE string DEFAULT 'ACTIVE' ASSERT $value INSIDE ['ACTIVE', 'MERGED', 'INACTIVE'] PERMISSIONS FULL;
DEFINE FIELD updated_at ON contact_master_map TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX cmm_linkage_idx ON contact_master_map FIELDS linkage_id UNIQUE;
DEFINE INDEX cmm_primary_idx ON contact_master_map FIELDS primary_lead;


-- ------------------------------
-- TABLE DATA: contact_master_map
-- ------------------------------


-- ------------------------------
-- TABLE: conversation
-- ------------------------------

DEFINE TABLE conversation TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD channel ON conversation TYPE record<channel> PERMISSIONS FULL;
DEFINE FIELD created_at ON conversation TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD external_source_leadid ON conversation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD last_message_at ON conversation TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD lead ON conversation TYPE record<lead> PERMISSIONS FULL;
DEFINE FIELD sentiment ON conversation TYPE none | string ASSERT $value = NONE OR $value INSIDE ['POSITIVE', 'NEUTRAL', 'NEGATIVE'] PERMISSIONS FULL;
DEFINE FIELD started_at ON conversation TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD summary ON conversation TYPE none | string PERMISSIONS FULL;

DEFINE INDEX conv_channel_idx ON conversation FIELDS channel;
DEFINE INDEX conv_lead_idx ON conversation FIELDS lead;

DEFINE EVENT conversation_graph_edge ON conversation WHEN $event = 'CREATE' THEN { LET $l = $after.lead; IF $l != NONE { (RELATE $l -> has_conversation -> $after).id }; };

