-- ------------------------------
-- TABLE: file_metadata
-- ------------------------------

DEFINE TABLE file_metadata TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD bucket_name ON file_metadata TYPE string DEFAULT 'vitalai_files' PERMISSIONS FULL;
DEFINE FIELD content_type ON file_metadata TYPE none | string PERMISSIONS FULL;
DEFINE FIELD conversation_id ON file_metadata TYPE none | string PERMISSIONS FULL;
DEFINE FIELD created_at ON file_metadata TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD file_path ON file_metadata TYPE string PERMISSIONS FULL;
DEFINE FIELD lead_id ON file_metadata TYPE none | string PERMISSIONS FULL;
DEFINE FIELD organisation ON file_metadata TYPE none | record<organisation> PERMISSIONS FULL;
DEFINE FIELD original_name ON file_metadata TYPE none | string PERMISSIONS FULL;
DEFINE FIELD public_url ON file_metadata TYPE string PERMISSIONS FULL;
DEFINE FIELD quotation_id ON file_metadata TYPE none | string PERMISSIONS FULL;
DEFINE FIELD size_bytes ON file_metadata TYPE none | int PERMISSIONS FULL;
DEFINE FIELD updated_at ON file_metadata TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD uploaded_by ON file_metadata TYPE string DEFAULT 'system' PERMISSIONS FULL;

DEFINE INDEX fm_lead ON file_metadata FIELDS lead_id;
DEFINE INDEX fm_org ON file_metadata FIELDS organisation;
DEFINE INDEX fm_path ON file_metadata FIELDS file_path UNIQUE;
DEFINE INDEX fm_quote ON file_metadata FIELDS quotation_id;
DEFINE INDEX fm_time ON file_metadata FIELDS created_at;


