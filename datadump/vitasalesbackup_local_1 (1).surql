-- ------------------------------
-- TABLE: lead_stage
-- ------------------------------

DEFINE TABLE lead_stage TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD active ON lead_stage TYPE bool DEFAULT true PERMISSIONS FULL;
DEFINE FIELD auto_followup ON lead_stage TYPE bool DEFAULT false PERMISSIONS FULL;
DEFINE FIELD created_at ON lead_stage TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD event_type ON lead_stage TYPE none | string PERMISSIONS FULL;
DEFINE FIELD followup_delay_hours ON lead_stage TYPE none | int PERMISSIONS FULL;
DEFINE FIELD followup_max_repeats ON lead_stage TYPE int DEFAULT 1 PERMISSIONS FULL;
DEFINE FIELD followup_message_template ON lead_stage TYPE none | string PERMISSIONS FULL;
DEFINE FIELD followup_period ON lead_stage TYPE string DEFAULT 'ONCE' PERMISSIONS FULL;
DEFINE FIELD is_quotation ON lead_stage TYPE bool DEFAULT false PERMISSIONS FULL;
DEFINE FIELD is_terminal ON lead_stage TYPE bool DEFAULT false PERMISSIONS FULL;
DEFINE FIELD metadata ON lead_stage TYPE none | object FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD organisation ON lead_stage TYPE record<organisation> PERMISSIONS FULL;
DEFINE FIELD stage_key ON lead_stage TYPE string PERMISSIONS FULL;
DEFINE FIELD stage_name ON lead_stage TYPE string PERMISSIONS FULL;
DEFINE FIELD stage_order ON lead_stage TYPE int PERMISSIONS FULL;
DEFINE FIELD updated_at ON lead_stage TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX ls_org_idx ON lead_stage FIELDS organisation;
DEFINE INDEX ls_org_key_idx ON lead_stage FIELDS organisation, stage_key UNIQUE;


-- ------------------------------
-- TABLE DATA: lead_stage
-- ------------------------------

