01T10:10:59.076279400Z' }, { attributes: { capacity: '6000 CMH', cooling_area: '2000 sqft', power: '0.75 kW', type: 'evaporative' }, base_price: 22000f, created_at: d'2026-04-01T10:10:59.078064800Z', id: product:p008, name: 'Evaporative Cooler', sku: 'EC-001', tax_rate: 18f, updated_at: d'2026-04-01T10:10:59.078074800Z' }, { attributes: { category: 'generic', type: 'cooler', usage: 'residential/commercial' }, base_price: 10000f, created_at: d'2026-04-01T10:10:59.472731Z', id: product:p009, name: 'Cooler', sku: 'COOL-001', tax_rate: 18f, updated_at: d'2026-04-01T10:10:59.472744200Z' }, { attributes: { category: 'industrial', type: 'chiller', usage: 'large scale cooling' }, base_price: 75000f, created_at: d'2026-04-01T10:10:59.477290800Z', id: product:p010, name: 'Chillers', sku: 'CHILL-001', tax_rate: 18f, updated_at: d'2026-04-01T10:10:59.477306700Z' }, { attributes: { category: 'hybrid', includes: ['cooler', 'chiller'], type: 'combo', usage: 'mixed requirement' }, base_price: 85000f, created_at: d'2026-04-01T10:10:59.479575800Z', id: product:p011, name: 'Cooler and Chillers', sku: 'COMBO-001', tax_rate: 18f, updated_at: d'2026-04-01T10:10:59.479597200Z' } ];

-- ------------------------------
-- TABLE: quotation
-- ------------------------------

DEFINE TABLE quotation TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD accepted_at ON quotation TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD currency ON quotation TYPE string DEFAULT 'INR' PERMISSIONS FULL;
DEFINE FIELD feedbackmsg ON quotation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD feedbackrating ON quotation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD generated_at ON quotation TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD isfeedback ON quotation TYPE bool PERMISSIONS FULL;
DEFINE FIELD lead ON quotation TYPE record<lead> PERMISSIONS FULL;
DEFINE FIELD model ON quotation TYPE string PERMISSIONS FULL;
DEFINE FIELD notes ON quotation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD pdf_url ON quotation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD products ON quotation TYPE array<object> FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD quotation_no ON quotation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD quote_id ON quotation TYPE string PERMISSIONS FULL;
DEFINE FIELD rejected_at ON quotation TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD rejection_reason ON quotation TYPE none | string PERMISSIONS FULL;
DEFINE FIELD sent_at ON quotation TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD sent_via ON quotation TYPE none | string ASSERT $value = NONE OR $value INSIDE ['WHATSAPP', 'EMAIL', 'BOTH'] PERMISSIONS FULL;
DEFINE FIELD status ON quotation TYPE string DEFAULT 'DRAFT' ASSERT $value INSIDE ['DRAFT', 'GENERATED', 'SENT', 'ACCEPTED', 'REJECTED'] PERMISSIONS FULL;
DEFINE FIELD subtotal ON quotation TYPE none | float PERMISSIONS FULL;
DEFINE FIELD tax_amount ON quotation TYPE none | float PERMISSIONS FULL;
DEFINE FIELD total_amount ON quotation TYPE none | float PERMISSIONS FULL;
DEFINE FIELD updated_at ON quotation TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX q_lead_idx ON quotation FIELDS lead;
DEFINE INDEX q_no_idx ON quotation FIELDS quotation_no;
DEFINE INDEX q_status_idx ON quotation FIELDS status;

DEFINE EVENT on_quotation_accepted ON quotation WHEN $event = 'UPDATE' AND $after.status = 'ACCEPTED' AND $before.status != 'ACCEPTED' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.lead AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.lead, event_type = 'QUOTATION_ACCEPTED', lead_state = 'CLOSED', triggered_by = 'agent', channel = (SELECT VALUE source_channel FROM ONLY $after.lead), payload = { quotation_id: <string> $after.id, total_amount: $after.total_amount, accepted_at: $after.accepted_at ?? time::now() }, created_at = time::now(); UPDATE $after.lead SET state = 'CLOSED', updated_at = time::now(); };
DEFINE EVENT on_quotation_created ON quotation WHEN $event = 'CREATE' THEN { LET $lead = <record> $after.lead; (RELATE $lead -> generated_quotation -> $after).id; CREATE event_log SET lead_id = <string> $after.lead, event_type = 'QUOTATION_CREATED', lead_state = 'SALES_QUALIFIED', triggered_by = 'system', channel = (SELECT VALUE source_channel FROM ONLY $after.lead), payload = { quotation_id: <string> $after.id, quotation_no: $after.quotation_no, total_amount: $after.total_amount, currency: $after.currency }, created_at = time::now(); };
DEFINE EVENT on_quotation_rejected ON quotation WHEN $event = 'UPDATE' AND $after.status = 'REJECTED' AND $before.status != 'REJECTED' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.lead AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.lead, event_type = 'QUOTATION_REJECTED', lead_state = 'CLOSED', triggered_by = 'agent', channel = (SELECT VALUE source_channel FROM ONLY $after.lead), payload = { quotation_id: <string> $after.id, rejection_reason: $after.rejection_reason }, created_at = time::now(); UPDATE $after.lead SET state = 'CLOSED', updated_at = time::now(); };
DEFINE EVENT on_quotation_sent ON quotation WHEN $event = 'UPDATE' AND $after.status = 'SENT' AND $before.status != 'SENT' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.lead AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.lead, event_type = 'QUOTE_SENT', lead_state = 'QUOTATION_SENT', triggered_by = 'agent', channel = (SELECT VALUE source_channel FROM ONLY $after.lead), payload = { quotation_id: <string> $after.id, quotation_no: $after.quotation_no, pdf_url: $after.pdf_url, total_amount: $after.total_amount, sent_via: $after.sent_via }, created_at = time::now(); UPDATE $after.lead SET state = 'QUOTATION_SENT', updated_at = time::now(); };

-- ------------------------------
