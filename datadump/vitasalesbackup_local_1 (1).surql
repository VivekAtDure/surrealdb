-- ------------------------------
-- TABLE: files
-- ------------------------------

DEFINE TABLE files TYPE ANY SCHEMALESS PERMISSIONS NONE;

DEFINE FIELD content_type ON files TYPE string PERMISSIONS FULL;
DEFINE FIELD created_at ON files TYPE datetime PERMISSIONS FULL;
DEFINE FIELD name ON files TYPE string PERMISSIONS FULL;
DEFINE FIELD path ON files TYPE string PERMISSIONS FULL;



-- ------------------------------
-- TABLE DATA: files
-- ------------------------------


-- ------------------------------
-- TABLE: followup_task
-- ------------------------------

DEFINE TABLE followup_task TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD channel ON followup_task TYPE none | record<channel> PERMISSIONS FULL;
DEFINE FIELD created_at ON followup_task TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD lead_id ON followup_task TYPE string PERMISSIONS FULL;
DEFINE FIELD message ON followup_task TYPE none | string PERMISSIONS FULL;
DEFINE FIELD scheduled_at ON followup_task TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD sent_at ON followup_task TYPE none | datetime PERMISSIONS FULL;
DEFINE FIELD `sequence` ON followup_task TYPE int DEFAULT 1 PERMISSIONS FULL;
DEFINE FIELD status ON followup_task TYPE string DEFAULT 'PENDING' ASSERT $value INSIDE ['PENDING', 'SENT', 'RESPONDED', 'CANCELLED', 'ESCALATED', 'FAILED'] PERMISSIONS FULL;
DEFINE FIELD task_type ON followup_task TYPE string PERMISSIONS FULL;
DEFINE FIELD updated_at ON followup_task TYPE datetime VALUE time::now() PERMISSIONS FULL;

DEFINE INDEX ft_lead_idx ON followup_task FIELDS lead_id;
DEFINE INDEX ft_sched_idx ON followup_task FIELDS scheduled_at;
DEFINE INDEX ft_status_idx ON followup_task FIELDS status;

DEFINE EVENT followup_graph_edge ON followup_task WHEN $event = 'CREATE' THEN { LET $l = type::record($after.lead_id); (RELATE $l -> has_followup_task -> $after).id; };
DEFINE EVENT on_followup_task_responded ON followup_task WHEN $event = 'UPDATE' AND $after.status = 'RESPONDED' AND $before.status != 'RESPONDED' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = $after.lead_id AND id != $after.id AND status = 'PENDING' };

