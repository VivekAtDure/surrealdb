-- TABLE DATA: interested_in
-- ------------------------------


-- ------------------------------
-- TABLE: lead
-- ------------------------------

DEFINE TABLE lead TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD ai_confidence ON lead TYPE none | float PERMISSIONS FULL;
DEFINE FIELD city ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD classification ON lead TYPE string DEFAULT 'NON-SALES' ASSERT $value INSIDE ['SALES', 'NON-SALES'] PERMISSIONS FULL;
DEFINE FIELD completeness ON lead TYPE string DEFAULT 'INCOMPLETE' ASSERT $value INSIDE ['COMPLETE', 'INCOMPLETE'] PERMISSIONS FULL;
DEFINE FIELD contact_id ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD country ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD created_at ON lead TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD designation ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD email ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD external_source_leadid ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD lead_source ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD master_id ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD name ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD organisation ON lead TYPE none | record<organisation> DEFAULT organisation:1 VALUE $value OR (organisation:1) PERMISSIONS FULL;
DEFINE FIELD organization ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD phone ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD product_interest ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD source_channel ON lead TYPE none | record<channel> PERMISSIONS FULL;
DEFINE FIELD state ON lead TYPE string DEFAULT 'NEW_LEAD' PERMISSIONS FULL;
DEFINE FIELD state_location ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD updated_at ON lead TYPE datetime VALUE time::now() PERMISSIONS FULL;
DEFINE FIELD whatsapp ON lead TYPE none | string PERMISSIONS FULL;
DEFINE FIELD whatsapp_no ON lead TYPE none | string PERMISSIONS FULL;

DEFINE INDEX idx_lead_identity ON lead FIELDS email, phone, whatsapp;
DEFINE INDEX lead_contact_idx ON lead FIELDS contact_id;
DEFINE INDEX lead_email_idx ON lead FIELDS email;
DEFINE INDEX lead_extid_idx ON lead FIELDS external_source_leadid;
DEFINE INDEX lead_phone_idx ON lead FIELDS phone;
DEFINE INDEX lead_state_idx ON lead FIELDS state;
DEFINE INDEX lead_wa_idx ON lead FIELDS whatsapp_no;

DEFINE EVENT on_lead_closed ON lead WHEN $event = 'UPDATE' AND $after.state = 'CLOSED' AND $before.state != 'CLOSED' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.id AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.id, event_type = 'LEAD_CLOSED', lead_state = 'CLOSED', triggered_by = 'agent', channel = $after.source_channel, payload = { closed_at: time::now(), classification: $after.classification }, created_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'CLOSED', triggered_by = 'agent', channel = $after.source_channel; };
DEFINE EVENT on_lead_created ON lead WHEN $event = 'CREATE' THEN { CREATE event_log SET lead_id = <string> $after.id, event_type = 'LEAD_CREATED', lead_state = $after.state, triggered_by = 'system', channel = $after.source_channel, payload = { phone: $after.phone, email: $after.email, external_id: $after.external_source_leadid }, created_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = NONE, to_state = $after.state ?? 'NEW_LEAD', triggered_by = 'system', channel = $after.source_channel; };
DEFINE EVENT on_lead_manual_followup ON lead WHEN $event = 'UPDATE' AND $after.state = 'MANUAL_FOLLOW_UP' AND $before.state != 'MANUAL_FOLLOW_UP' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.id AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.id, event_type = 'MANUAL_FOLLOWUP_INITIATED', lead_state = 'MANUAL_FOLLOW_UP', triggered_by = 'agent', channel = $after.source_channel, payload = { note: 'Agent manually following up with customer' }, created_at = time::now(); CREATE followup_task SET lead_id = <string> $after.id, task_type = 'MANUAL_FOLLOWUP', channel = $after.source_channel, message = string::concat('Hi ', $after.name ?? 'there', '! Following up on your recent inquiry. How can we help you today?'), `sequence` = 1, status = 'PENDING', scheduled_at = time::now() + 2h, updated_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'MANUAL_FOLLOW_UP', triggered_by = 'agent', channel = $after.source_channel; };
DEFINE EVENT on_lead_new_lead ON lead WHEN $event = 'UPDATE' AND $after.state = 'NEW_LEAD' AND $before.state != 'NEW_LEAD' THEN { CREATE event_log SET lead_id = <string> $after.id, event_type = 'INITIAL_INQUIRY_CAPTURED', lead_state = 'NEW_LEAD', triggered_by = 'system', channel = $after.source_channel, payload = { product: $after.product_interest, classification: $after.classification }, created_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'NEW_LEAD', triggered_by = 'system', channel = $after.source_channel; };
DEFINE EVENT on_lead_qualified ON lead WHEN $event = 'UPDATE' AND $after.state = 'SALES_QUALIFIED' AND $before.state != 'SALES_QUALIFIED' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.id AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.id, event_type = 'LEAD_QUALIFIED', lead_state = 'SALES_QUALIFIED', triggered_by = 'system', channel = $after.source_channel, payload = { product: $after.product_interest, confidence: $after.ai_confidence }, created_at = time::now(); CREATE event_log SET lead_id = <string> $after.id, event_type = 'SALES_CONTEXT_LOCKED', lead_state = 'SALES_QUALIFIED', triggered_by = 'system', channel = $after.source_channel, payload = { locked_at: time::now() }, created_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'SALES_QUALIFIED', triggered_by = 'system', channel = $after.source_channel; };
DEFINE EVENT on_lead_quotation_followup ON lead WHEN $event = 'UPDATE' AND $after.state = 'QUOTATION_FOLLOW_UP' AND $before.state != 'QUOTATION_FOLLOW_UP' THEN { CREATE event_log SET lead_id = <string> $after.id, event_type = 'QUOTE_FOLLOWUP_INITIATED', lead_state = 'QUOTATION_FOLLOW_UP', triggered_by = 'system', channel = $after.source_channel, payload = { round: 1 }, created_at = time::now(); CREATE followup_task SET lead_id = <string> $after.id, task_type = 'QUOTE_REPEAT_FOLLOWUP', channel = $after.source_channel, message = string::concat('Hi ', $after.name ?? 'there', '! Wanted to follow up once more on your quotation. ', 'Let us know if you have any questions or need any adjustments. 🙏'), `sequence` = 2, status = 'PENDING', scheduled_at = time::now() + 2d, updated_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'QUOTATION_FOLLOW_UP', triggered_by = 'system', channel = $after.source_channel; };
DEFINE EVENT on_lead_quotation_negotiation ON lead WHEN $event = 'UPDATE' AND $after.state = 'QUOTATION_NEGOTIATION' AND $before.state != 'QUOTATION_NEGOTIATION' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.id AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.id, event_type = 'NEGOTIATION_STARTED', lead_state = 'QUOTATION_NEGOTIATION', triggered_by = 'agent', channel = $after.source_channel, payload = { note: 'Customer is negotiating price or terms' }, created_at = time::now(); CREATE event_log SET lead_id = <string> $after.id, event_type = 'FOLLOWUP_SEQUENCE_INCREMENTED', lead_state = 'QUOTATION_NEGOTIATION', triggered_by = 'system', channel = $after.source_channel, payload = { sequence: 2 }, created_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'QUOTATION_NEGOTIATION', triggered_by = 'agent', channel = $after.source_channel; };
DEFINE EVENT on_lead_quotation_sent ON lead WHEN $event = 'UPDATE' AND $after.state = 'QUOTATION_SENT' AND $before.state != 'QUOTATION_SENT' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.id AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.id, event_type = 'QUOTE_SENT', lead_state = 'QUOTATION_SENT', triggered_by = 'agent', channel = $after.source_channel, payload = { sent_at: time::now() }, created_at = time::now(); CREATE followup_task SET lead_id = <string> $after.id, task_type = 'QUOTE_FOLLOWUP', channel = $after.source_channel, message = string::concat('Hi ', $after.name ?? 'there', '! Just checking in on the quotation we sent. Have you had a chance to review it? 😊'), `sequence` = 1, status = 'PENDING', scheduled_at = time::now() + 2d, updated_at = time::now(); CREATE event_log SET lead_id = <string> $after.id, event_type = 'FOLLOW_UP_TASK_CREATED', lead_state = 'QUOTATION_SENT', triggered_by = 'system', channel = $after.source_channel, payload = { task_type: 'QUOTE_FOLLOWUP', delay_hours: 48 }, created_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'QUOTATION_SENT', triggered_by = 'agent', channel = $after.source_channel; };
DEFINE EVENT on_lead_sales_followup ON lead WHEN $event = 'UPDATE' AND $after.state = 'SALES_FOLLOW_UP' AND $before.state != 'SALES_FOLLOW_UP' THEN { UPDATE followup_task SET status = 'CANCELLED', updated_at = time::now() WHERE lead_id = <string> $after.id AND status = 'PENDING'; CREATE event_log SET lead_id = <string> $after.id, event_type = 'SALES_FOLLOWUP_INITIATED', lead_state = 'SALES_FOLLOW_UP', triggered_by = 'system', channel = $after.source_channel, payload = { completeness: $after.completeness, product: $after.product_interest }, created_at = time::now(); CREATE event_log SET lead_id = <string> $after.id, event_type = 'FOLLOW_UP_TASK_CREATED', lead_state = 'SALES_FOLLOW_UP', triggered_by = 'system', channel = $after.source_channel, payload = { task_type: 'SALES_FOLLOWUP', delay_hours: 4 }, created_at = time::now(); CREATE followup_task SET lead_id = <string> $after.id, task_type = 'SALES_FOLLOWUP', channel = $after.source_channel, message = string::concat('Hi ', $after.name ?? 'there', '! We need a few more details to prepare your quotation. ', 'Could you share: quantity needed, delivery location, and rental or purchase?'), `sequence` = 1, status = 'PENDING', scheduled_at = time::now() + 4h, updated_at = time::now(); CREATE lead_state_history SET lead_id = <string> $after.id, from_state = $before.state, to_state = 'SALES_FOLLOW_UP', triggered_by = 'system', channel = $after.source_channel; };

